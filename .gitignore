assets/video/_vonly_*.mp4
assets/video/_opening_only.mp4

# 사이트가 참조하지 않는 TTS 원본/중간 음성(용량만 큼; 최종 영상엔 오디오가 embed됨)
assets/audio/

# 파이썬 캐시/OS 잡파일
__pycache__/
*.pyc
.DS_Store
Thumbs.db

# wrangler 배포 캐시
.wrangler/

# 2편 영상 작업물 — 웹 미참조(게시처=유튜브). 디스크엔 보존, 배포/공개 URL엔 제외.
assets/images/ep02/
